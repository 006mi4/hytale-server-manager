{
  "name": "hytale-server-manager",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.node.json && node -e \"require('fs').cpSync('electron/migrations','dist-electron/migrations',{recursive:true})\" && concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:electron": "tsc -p tsconfig.node.json && node -e \"require('fs').cpSync('electron/migrations','dist-electron/migrations',{recursive:true})\"",
    "build": "vite build && tsc -p tsconfig.node.json && node -e \"require('fs').cpSync('electron/migrations','dist-electron/migrations',{recursive:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "npm run build && electron-builder --dir",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "i18next": "^25.10.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "typescript": "^6.0.2",
    "unzip-stream": "^0.3.4",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
